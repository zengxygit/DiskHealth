@startuml DiskHealth_ClassDiagram
skinparam classAttributeIconSize 0
skinparam classFontSize 13
skinparam classHeaderBackgroundColor #1976D2
skinparam classHeaderFontColor #FFFFFF
skinparam classBorderColor #0D47A1
skinparam classBackgroundColor #E3F2FD
skinparam arrowColor #37474F
skinparam arrowFontSize 11
skinparam packageBackgroundColor #F5F7FA
skinparam packageBorderColor #90A4AE
skinparam stereotypeCBackgroundColor #FFF9C4
skinparam noteBackgroundColor #FFFDE7
skinparam noteBorderColor #F9A825

title DiskHealth — 类图 (Class Diagram)

' ══════════════════════════════
' Package: 表现层 UI Layer
' ══════════════════════════════
package "表现层 (UI Layer)" #E3F2FD {

  class CDiskHealthMainWin {
    ' 继承自 CBPWinFrm (QWidget)
    - DiskInfoMgr* m_pDiskMgr
    - CBPComboBox* m_pDiskList
    - CBPLabel* m_pLeftLb
    - CBPLabel* m_pRightLb
    - CBPLabel* m_pStatusText
    - CBPLabel* m_pHealthPersentTxt
    - CBPLabel* m_pTempTxt
    - CBPLabel* m_pTempStatusTxt
    - CBPImageButton* m_pRefreshBtn
    - CBPBox* m_pTopWid
    - QFrame* m_pDiskStatusInfo
    - QTableView* m_pAtrriList
    - CBPCheckBox* m_pAutoStartCheck
    - QVBoxLayout* m_pDiskStatusInfoLayout
    - QFrame* m_pTempWid
    - QFrame* m_pStatusWid
    - int m_currentDiskIndex
    - bool m_bFirstShow
    __
    + CDiskHealthMainWin(pDiskMgr: DiskInfoMgr*, parent: QWidget*)
    + ~CDiskHealthMainWin()
    + OnClose() : void <<override>>
    + onDiskInfosChanged() : void
    + onLanguageChanged() : void
    + onTempUnitChanged() : void
    + onSwitchToDisk(diskIndex: int) : void
    # showEvent(event: QShowEvent*) : void <<override>>
    - onDiskSelected(index: int) : void <<slot>>
    - onRefreshClicked() : void <<slot>>
    - onTemperatureClicked() : void <<slot>>
    - onAutoStartToggled(checked: bool) : void <<slot>>
    - onDoneClicked() : void <<slot>>
    - InitTitle() : void
    - Init() : void
    - InitDiskList() : void
    - InitStatusWid(layout: QBoxLayout*) : void
    - InitTempWid(layout: QBoxLayout*) : void
    - InitData() : void
    - InitInfo() : void
    - InitConnections() : void
    - loadDiskList() : void
    - updateDiskInfo(diskIndex: int) : void
    - updateStatusAndTemp(diskIndex: int) : void
    - updateDiskStatusInfo(diskIndex: int) : void
    - updateAttributeTable(diskIndex: int) : void
  }

  class AttrModel {
    ' 继承自 QAbstractItemModel
    # DiskInfoMgr* m_pMgr
    __
    + AttrModel(parent: DiskInfoMgr*)
    + reset() : void
    + parent(index: QModelIndex) : QModelIndex <<override>>
    + flags(index: QModelIndex) : Qt::ItemFlags <<override>>
    + index(row: int, col: int, parent: QModelIndex) : QModelIndex <<override>>
    + rowCount(parent: QModelIndex) : int <<override>>
    + columnCount(parent: QModelIndex) : int <<override>>
    + roleNames() : QHash<int, QByteArray> <<override>>
    + hasChildren(parent: QModelIndex) : bool <<override>>
    + data(index: QModelIndex, role: int) : QVariant <<override>>
  }

  enum ItemRoles {
    USER_STATUS = Qt::UserRole + 1
    USER_ID
    USER_ATTR
    USER_COUNT
    USER_HOLD
    USER_RAW
  }

  class CTrayIcon {
    ' 继承自 QObject, QAbstractNativeEventFilter
    - QIcon m_icoDefault
    - QTimer* m_pLeaveTimer
    - QRect m_IconRect
    - QWidget* m_pSysIcon
    - QMenu* m_menu
    - QList<QAction*> m_actions
    - QTimer m_createIconTimer
    - QPoint m_lastPos
    - clock_t createTime
    - bool showMenu
    - bool firstHover
    - clock_t lastHoverTime
    __
    + CTrayIcon(parent: QObject*)
    + ~CTrayIcon()
    + OnActivate() : void
    + StarListen() : void
    + CheckMouse() : void
    + inPos(pt: QPoint) : bool
    + onCreateIcon() : void
    # nativeEventFilter(eventType: QByteArray, message: void*, result: long*) : bool <<override>>
    __ signals __
    + sigExit() <<signal>>
    + sigShowFrame() <<signal>>
    + sigHoverEnter(x: int, y: int) <<signal>>
    + sigHoverLeave() <<signal>>
  }

  AttrModel +-- ItemRoles
}

' ══════════════════════════════
' Package: 管理层 Manager Layer
' ══════════════════════════════
package "管理层 (Manager Layer)" #E8F5E9 {

  class DiskInfoMgr {
    ' 继承自 QObject, QAbstractNativeEventFilter
    ' Q_PROPERTY: diskInfos, currentLanguage, isTempF
    # CAtaSmart m_Ata
    # QVariantList m_listDiskInfos
    # QStringList m_listStatusDes
    # QStringList m_listTempDes
    # QList<ListInfo> m_listRightInfo
    # QMap<QString, QMap<QString,QString>> m_attrNames
    # AttrModel m_model
    # QString m_strCurLang
    # QTranslator m_translator
    # CDiskHealthMainWin* m_pMainWin
    # RefreshThread m_refreshThread
    # CTrayIcon* m_tray
    # QWindow* m_pW
    # QTimer m_pCPUTimer
    # QTimer m_EPMTimer
    # QLocalSocket m_socket
    # QMap<int,int> m_mapStatus
    # QString m_strTheme
    # int m_iCPU
    # int m_iFirstCautionDisk
    # int m_iDiskIndex
    # bool m_bAutoStart
    # bool m_bEPMStart
    # bool m_bIsFullScreen
    # bool m_bRefreshForPop
    # bool m_bIsEPMDiscoery
    # bool m_bIsEPMPE
    # bool m_bIsTempF
    # bool m_bVisible
    __
    + DiskInfoMgr()
    + ~DiskInfoMgr()
    + loadInfo() : void <<Q_INVOKABLE>>
    + getDiskInfos() : QVariantList <<Q_INVOKABLE>>
    + getDiskStatus(index: int) : QVariantMap <<Q_INVOKABLE>>
    + getDiskStatusInfo(index: int) : QVariantList <<Q_INVOKABLE>>
    + getCautionDiskStatusInfo() : QVariantList <<Q_INVOKABLE>>
    + loadInfoList(index: int) : void <<Q_INVOKABLE>>
    + getModel() : QAbstractItemModel* <<Q_INVOKABLE>>
    + getCurrentLanguage() : QString <<Q_INVOKABLE>>
    + setCurrrentLanguage(lang: QString) : void <<Q_INVOKABLE>>
    + isAutoStart() : bool <<Q_INVOKABLE>>
    + delAutoStart() : void <<Q_INVOKABLE>>
    + addAutoStart() : void <<Q_INVOKABLE>>
    + refreshDisks() : void <<Q_INVOKABLE>>
    + setWindowIcon(w: QWindow*) : void <<Q_INVOKABLE>>
    + showWindow() : bool <<Q_INVOKABLE>>
    + doDone(check: bool) : bool <<Q_INVOKABLE>>
    + isTrayExist() : bool <<Q_INVOKABLE>>
    + doExit() : void <<Q_INVOKABLE>>
    + mousePos() : QPoint <<Q_INVOKABLE>>
    + isBusy() : bool <<Q_INVOKABLE>>
    + popCondition() : bool <<Q_INVOKABLE>>
    + screenSize() : QPoint <<Q_INVOKABLE>>
    + diskIndexArg() : int <<Q_INVOKABLE>>
    + refreshForPop() : void <<Q_INVOKABLE>>
    + showRaw(index: int) : bool <<Q_INVOKABLE>>
    + showFrame() : void <<Q_INVOKABLE>>
    + hoverLeave() : void <<Q_INVOKABLE>>
    + openUrl() : void <<Q_INVOKABLE>>
    + showFromCaution() : void <<Q_INVOKABLE>>
    + clickRefresh() : void <<Q_INVOKABLE>>
    + selectDisk(index: int) : void <<Q_INVOKABLE>>
    + setVisible(v: bool) : void <<Q_INVOKABLE>>
    + firstCautionIndex() : int <<Q_INVOKABLE>>
    + isTempF() : bool <<Q_INVOKABLE>>
    + setIsTempF(v: bool) : void <<Q_INVOKABLE>>
    + fileExists(file: QString) : bool <<Q_INVOKABLE>>
    + isMainland() : bool <<Q_INVOKABLE>>
    + theme() : QString <<Q_INVOKABLE>>
    + getPopLink(lang: QString) : QString <<Q_INVOKABLE>>
    + showWindowShadow() : bool <<Q_INVOKABLE>>
    + checkHasSmartError(index: int) : bool
    + setMaminWin(w: CDiskHealthMainWin*) : void
    + getFeature(index: int) : QString
    + GetAttributeDesc(pInfo: ATA_SMART_INFO*, dwId: ULONG) : QString
    + ProcessSectorAttr(info: ListInfo&, pInfo: ATA_SMART_INFO*, j: int) : bool
    + ProcessTempAttr(info: ListInfo&, pInfo: ATA_SMART_INFO*, j: int) : bool
