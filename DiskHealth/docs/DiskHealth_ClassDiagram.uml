  class RefreshThread {
    ' 继承自 QThread
    - DiskInfoMgr* m_mgr
    __
    + RefreshThread(parent: DiskInfoMgr*)
    # run() : void <<override>>
  }
}

' ══════════════════════════════
' Package: 数据层 Data Layer
' ══════════════════════════════
package "数据层 (Data Layer)" #FFF3E0 {

  class CAtaSmart {
    {static} + MAX_DISK : int = 64
    {static} + MAX_ATTRIBUTE : int = 30
    {static} + MAX_SEARCH_PHYSICAL_DRIVE : int = 56
    {static} + MAX_SEARCH_SCSI_PORT : int = 16
    {static} + MAX_SEARCH_SCSI_TARGET_ID : int = 8
    {static} + SCSI_MINIPORT_BUFFER_SIZE : int = 512
    + vars : CAtaList<ATA_SMART_INFO>
    + FlagUsbSat : BOOL
    + FlagUsbIodata : BOOL
    + FlagUsbSunplus : BOOL
    + FlagUsbLogitec : BOOL
    + FlagUsbProlific : BOOL
    + FlagUsbJmicron : BOOL
    + FlagUsbCypress : BOOL
    + FlagUsbASM1352R : BOOL
    + FlagUsbMemory : BOOL
    + FlagUsbNVMeJMicron : BOOL
    + FlagUsbNVMeASMedia : BOOL
    + FlagUsbNVMeRealtek : BOOL
    + FlagMegaRAID : BOOL
    - m_bAtaPassThrough : BOOL
    - m_bAtaPassThroughSmart : BOOL
    - m_bNVMeStorageQuery : BOOL
    - m_Os : OSVERSIONINFOEX
    __
    + CAtaSmart()
    + ~CAtaSmart()
    + Init(bFlagUsbMemory: BOOL, bWorkaround: BOOL, ...) : VOID
    + UpdateSmartInfo(i: DWORD) : DWORD
    + SetAtaPassThroughSmart(flag: BOOL) : VOID
    + GetSmartAttributeNVMeStorageQuery(driveId: int, ...) : BOOL
    + GetSmartAttributeNVMeIntel(driveId: int, ...) : BOOL
    + GetSmartAttributeNVMeSamsung(driveId: int, ...) : BOOL
    + GetSmartAttributeNVMeJMicron(driveId: int, ...) : BOOL
    + GetSmartAttributeNVMeASMedia(driveId: int, ...) : BOOL
    + GetSmartAttributeNVMeRealtek(driveId: int, ...) : BOOL
  }

  class ATA_SMART_INFO <<struct>> {
    + Model : TCHAR[]
    + SerialNumber : TCHAR[]
    + FirmwareRev : TCHAR[]
    + PhysicalDriveId : int
    + ScsiPort : int
    + ScsiTargetId : int
    + Temperature : DWORD
    + IsSsd : BOOL
    + DiskStatus : DISK_STATUS
    + DiskVendorId : VENDOR_ID
    + CommandType : COMMAND_TYPE
    + InterfaceType : INTERFACE_TYPE
    + Attribute[MAX_ATTRIBUTE] : SMART_ATTRIBUTE
    + AttributeCount : int
    + SmartReadData[512] : UCHAR
    + PowerOnRawValue : DWORD
    + AlarmTemperature : int
    + AlarmHealthStatus : int
    + Threshold05 : DWORD
    + ThresholdC5 : DWORD
    + ThresholdC6 : DWORD
    + ThresholdFF : DWORD
    + TotalDiskSize : ULONGLONG
    + TotalBytesRead : ULONGLONG
    + TotalBytesWritten : ULONGLONG
  }

  class SMART_ATTRIBUTE <<struct>> {
    + Id : BYTE
    + StatusFlags : WORD
    + CurrentValue : BYTE
    + WorstValue : BYTE
    + RawValue[6] : BYTE
    + Reserved : BYTE
  }

  class ListInfo <<struct>> {
    + iconId : int
    + attrId : DWORD
    + attrName : QString
    + curValue : DWORD
    + threshold : QString
    + raw : QString
  }

  class NVMeInterpreter <<utility>> {
    {static} + NVMeSmartToATASmart(NVMeSmartBuf: UCHAR*, ATASmartBuf: void*) : void
  }

  class SlotSpeedGetter {
    + GetSlotSpeed(...) : DWORD
  }

  note right of NVMeInterpreter
    将 NVMe SMART/Health
    Information Log 原始字节
    转换为 ATA SMART 属性格式
    (NVME_ATTRIBUTE = 15)
  end note
}

' ══════════════════════════════
' Package: 枚举类型
' ══════════════════════════════
package "枚举类型 (Enumerations)" #FCE4EC {

  enum DISK_STATUS {
    DISK_STATUS_UNKNOWN = 0
    DISK_STATUS_GOOD
    DISK_STATUS_CAUTION
    DISK_STATUS_BAD
  }

  enum VENDOR_ID {
    HDD_GENERAL = 0
    SSD_GENERAL = 1
    SSD_VENDOR_INTEL = 5
    SSD_VENDOR_SAMSUNG = 6
    SSD_VENDOR_WDC = 11
    SSD_VENDOR_SEAGATE = 10
    SSD_VENDOR_NVME = 19
    SSD_VENDOR_YMTC = 30
    SSD_VENDOR_MAX = 99
    USB_VENDOR_BUFFALO = 0x0411
    USB_VENDOR_ALL = 0xFFFF
  }

  enum COMMAND_TYPE {
    CMD_TYPE_UNKNOWN = 0
    CMD_TYPE_PHYSICAL_DRIVE
    CMD_TYPE_SCSI_MINIPORT
    CMD_TYPE_SAT
    CMD_TYPE_NVME_SAMSUNG
    CMD_TYPE_NVME_INTEL
    CMD_TYPE_NVME_STORAGE_QUERY
    CMD_TYPE_NVME_JMICRON
    CMD_TYPE_NVME_ASMEDIA
    CMD_TYPE_NVME_REALTEK
    CMD_TYPE_NVME_INTEL_RST
    CMD_TYPE_CSMI
    CMD_TYPE_WMI
    CMD_TYPE_MEGARAID
  }

  enum INTERFACE_TYPE {
    INTERFACE_TYPE_UNKNOWN = 0
    INTERFACE_TYPE_PATA
    INTERFACE_TYPE_SATA
    INTERFACE_TYPE_USB
    INTERFACE_TYPE_IEEE1394
    INTERFACE_TYPE_SCSI
    INTERFACE_TYPE_NVME
  }

  enum SMART_STATUS {
    SMART_STATUS_NO_CHANGE = 0
    SMART_STATUS_MINOR_CHANGE
    SMART_STATUS_MAJOR_CHANGE
  }

  enum TRANSFER_MODE {
    TRANSFER_MODE_UNKNOWN = 0
    TRANSFER_MODE_PIO
    TRANSFER_MODE_SATA_150
    TRANSFER_MODE_SATA_300
    TRANSFER_MODE_SATA_600
  }
}

' ══════════════════════════════
' 关系定义
' ══════════════════════════════

' 组合关系 (Composition)
DiskInfoMgr *-- "1" RefreshThread      : 包含\nm_refreshThread
DiskInfoMgr *-- "1" AttrModel          : 包含\nm_model
DiskInfoMgr *-- "1" CAtaSmart          : 包含\nm_Ata
CAtaSmart   *-- "0..64" ATA_SMART_INFO : vars数组
ATA_SMART_INFO *-- "0..30" SMART_ATTRIBUTE : Attribute[]

' 聚合关系 (Aggregation)
DiskInfoMgr o-- "0..1" CTrayIcon       : 可选\nm_tray

' 关联关系 (Association)
DiskInfoMgr --> CDiskHealthMainWin     : 持有指针\nm_pMainWin
CDiskHealthMainWin --> DiskInfoMgr     : 持有指针\nm_pDiskMgr
AttrModel --> DiskInfoMgr              : 反向引用\nm_pMgr
RefreshThread --> DiskInfoMgr          : 调用\nm_mgr

' 依赖关系 (Dependency)
CAtaSmart ..> NVMeInterpreter          : <<use>>
CAtaSmart ..> SlotSpeedGetter          : <<use>>

' 枚举使用
ATA_SMART_INFO ..> DISK_STATUS         : <<use>>
ATA_SMART_INFO ..> VENDOR_ID           : <<use>>
ATA_SMART_INFO ..> COMMAND_TYPE        : <<use>>
ATA_SMART_INFO ..> INTERFACE_TYPE      : <<use>>

note top of DiskInfoMgr
  核心业务控制器
  运行于: 主线程
  负责协调所有模块间通信
end note

note top of RefreshThread
  后台工作线程
  调用 DiskInfoMgr::loadInfo()
  避免阻塞 UI 线程
end note

note top of CAtaSmart
  SMART 核心引擎
  运行于: 工作线程
  支持 IOCTL / NVMe / WMI
  多路径读取策略
end note

@enduml
